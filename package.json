{
  "name": "@hippodid/openclaw-plugin",
  "version": "1.1.2",
  "description": "Cloud sync for MEMORY.md with structured character memory. Survives context compaction.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SameThoughts/hippodid-openclaw-plugin.git"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "character-memory",
    "cloud-sync",
    "hippodid",
    "ai-memory"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "id": "hippodid-openclaw-plugin"
  },
  "files": [
    "dist",
    "src",
    "skills",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
